[core]
	quotePath = false
	trustctime = false
	precomposeUnicode = false
	pager = cat
	eol = lf
	ignoreCase = false
	untrackedCache = true
[column]
	ui = auto
[merge]
	log = true
[apply]
	whitespace = fix
[help]
	autocorrect = immediate
[rerere]
	enabled = true
	autoUpdate = true
[color "diff"]
	meta = yellow bold
	frag = magenta
	plain = white bold
	old = red bold
	new = green bold
	commit = yellow bold
	func = green dim
	whitespace = red reverse
[color "status"]
	added = yellow
	changed = green
	untracked = cyan
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[diff]
	renames = copies
	algorithm = histogram
	wsErrorHighlight = all
	context = 4
	mnemonicPrefix = true
[diff "bin"]
	textconv = hexdump -v -C
[credential]
	helper = store
[status]
	showUntrackedFiles = no
[pull]
	rebase = true
[push]
	default = current
	followTags = true
	autoSetupRemote = true
[rebase]
	abbreviateCommands = true
	autoSquash = true
	autoStash = true
	updateRefs = true
[alias]
	dif = diff
	git = !exec git
[branch]
	autosetupmerge = always
[http]
	sslverify = false
	postBuffer = 1048576000
[submodule]
	fetchJobs = 0
[fetch]
	prune = true
	pruneTags = true
	tags = true
	recurseSubmodules = true
	parallel = 0
[tag]
	sort = version:refname
[am]
	threeWay = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[init]
	defaultBranch = master
[advice]
	skippedCherryPicks = false
[include]
	path = ~/.gitconfig.local
